# Firebase Hosting deploy ignore list
# These files/folders are excluded from ALL firebase deploy operations

# Internal developer docs — never deploy
_unpublished/

# README assets (only for GitHub display, not web app)
assets/

# Source code (only dist/ goes to hosting)
src/
functions/src/

# Local environment & secrets
.env
.env.local
.env.*.local

# Dev & test artifacts
node_modules/
coverage/
dev-dist/
*.log

# Firebase CLI cache
.firebase/

# Claude agent memory
.claude/

# Editor files
.vscode/
.idea/
.DS_Store

# Git
.git/
.gitignore
