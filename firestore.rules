rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Robust Admin Check
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.role == 'super_admin' ||
        request.auth.token.role == 'admin' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.activeRole == 'super_admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.activeRole == 'admin'
        ))
      );
    }
    
    // Check if the user is creating a document that claims to be owned by them
    function isCreatingForSelf(emailField) {
      return isSignedIn() && request.resource.data[emailField] == request.auth.token.email;
    }

    // --- COLLECTION RULES ---

    // 1. USERS
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); // Strictly admin-only listing. Community leaderboard requires Admin SDK or Cloud Function in production.
      allow write: if isOwner(userId) || isAdmin();
    }
    
    // 2. PETS
    match /pets/{petId} {
      allow read: if true; 
      
      // Hardened Create: Must be signed in AND ownerEmail must match auth token
      allow create: if isSignedIn() && (
        request.resource.data.ownerEmail == request.auth.token.email ||
        // Allow creating stray/shelter pets if the user's role permits (simplified check for now, trusting the email match)
        // If ownerEmail is null (stray), we allow it if user is logged in
        request.resource.data.ownerEmail == null
      );
      
      allow update, delete: if isAdmin() || (isSignedIn() && (
        resource.data.ownerEmail == request.auth.token.email || 
        request.auth.token.email in resource.data.guardianEmails
      ));
    }

    // 3. CLINICS
    match /vet_clinics/{clinicId} {
      allow read: if true;
      // Hardened Create: Vet email must match
      allow create: if isCreatingForSelf('vetEmail');
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.vetEmail == request.auth.token.email);
    }

    // 4. DONATIONS
    match /donations/{donationId} {
      // Hardened Read: Allow if public OR if admin. 
      // NOTE: Queries MUST filter by isPublic == true for this to work for non-admins.
      allow read: if (resource.data.isPublic == true) || isAdmin();
      
      // Hardened Create: Public can create, BUT must enforce initial status
      allow create: if 
        request.resource.data.status == 'pending_payment' &&
        request.resource.data.approved == false &&
        request.resource.data.numericValue > 0 &&
        // Rate limiting check (basic): Timestamp must be close to request time
        request.resource.data.timestamp is number;

      allow update, delete: if isAdmin();
    }

    // 5. APPOINTMENTS
    match /appointments/{apptId} {
      allow read, write: if isSignedIn() && (
        request.auth.token.email == resource.data.vetEmail || 
        request.auth.token.email == request.resource.data.vetEmail || // for create
        exists(/databases/$(database)/documents/pets/$(resource.data.petId)) && (
          get(/databases/$(database)/documents/pets/$(resource.data.petId)).data.ownerEmail == request.auth.token.email
        )
      );
    }

    // 6. CHATS
    match /chats/{chatId} {
      allow read: if isSignedIn() && (
        request.auth.token.email == resource.data.ownerEmail || 
        request.auth.token.email == resource.data.finderEmail
      );
      
      // Hardened Write: Creation must involve the user as one of the participants
      allow create: if isSignedIn() && (
        request.resource.data.ownerEmail == request.auth.token.email || 
        request.resource.data.finderEmail == request.auth.token.email
      );
      
      allow update: if isSignedIn() && (
        resource.data.ownerEmail == request.auth.token.email || 
        resource.data.finderEmail == request.auth.token.email
      );
    }

    // 7. BLOG POSTS
    match /blog_posts/{postId} {
      allow read: if true;
      allow list: if true;
      allow write: if isAdmin();
      // Allow view increment by anyone
      allow update: if true && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']);
    }

    // 8. CONTACT MESSAGES
    match /contact_messages/{msgId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    
    // 9. ADMIN AUDIT LOGS
    match /admin_audit_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // 10. SYSTEM/MAIL
    match /mail/{mailId} {
      allow write: if isSignedIn();
    }
    
    // 11. METADATA
    match /metadata/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 12. SEARCH CONFIGURATION (For AI Optimization)
    match /search_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 13. OPTIMIZATION TRIALS (For AI Optimization)
    match /optimization_trials/{trialId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // 14. SEARCH INTERACTIONS (For AI Optimization Feedback)
    match /search_interactions/{interactionId} {
      allow create: if true; // Allow anyone to record an interaction (view/click)
      allow read: if isAdmin();
    }

    // 15. SAVED SEARCHES (User Identikits)
    match /saved_searches/{searchId} {
      allow create: if isSignedIn() && request.resource.data.userEmail == request.auth.token.email;
      allow read, update, delete: if isSignedIn() && resource.data.userEmail == request.auth.token.email;
    }

    // --- STRIPE EXTENSION RULES ---
    match /customers/{uid} {
      allow read: if request.auth.uid == uid;

      match /checkout_sessions/{id} {
        allow read, write: if request.auth.uid == uid;
      }
      match /subscriptions/{id} {
        allow read: if request.auth.uid == uid;
      }
      match /payments/{id} {
        allow read: if request.auth.uid == uid;
      }
    }
  }
}