rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Robust Admin Check
    function isAdmin() {
      return isSignedIn() && (
        // 1. Email Whitelist (Reliable for core admins)
        (request.auth.token.keys().hasAny(['email']) && (
            request.auth.token.email.matches('(?i).*(admin|yas)@pawprint\\.ai') ||
            request.auth.token.email in ['admin@pawprint.ai', 'yas@pawprint.ai', 'super@pawprint.ai']
        )) ||

        // 2. Custom Claims — fastest check, set via Firebase Admin SDK
        (request.auth.token.keys().hasAny(['role']) && request.auth.token.role in ['super_admin', 'admin']) ||
        (request.auth.token.keys().hasAny(['admin']) && request.auth.token.admin == true) ||
        (request.auth.token.keys().hasAny(['super_admin']) && request.auth.token.super_admin == true) ||

        // 3. Firestore Document (fallback — slower due to cross-document read)
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.activeRole in ['super_admin', 'admin'] ||
           (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.keys().hasAny(['roles']) &&
            ('admin' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles ||
             'super_admin' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles))
        ))
      );
    }
    
    // Check if the user is creating a document that claims to be owned by them
    function isCreatingForSelf(emailField) {
      return isSignedIn() && request.resource.data[emailField] == request.auth.token.email;
    }

    // --- COLLECTION RULES ---

    // 1. USERS
    match /users/{userId} {
      // Allow get and list for Admins (list is required for aggregation/count queries)
      // Users can read their own documents.
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isAdmin() || isOwner(userId);

      // User subcollections (usageStats, etc.)
      match /{subcollection}/{docId} {
        allow read, write: if isAdmin() || isOwner(userId);
      }
    }
    
    // 2. PETS
    match /pets/{petId} {
      allow read: if true; 
      
      // Hardened Create: Must be signed in AND ownerEmail must match auth token
      allow create: if isSignedIn() && (
        request.resource.data.ownerEmail == request.auth.token.email ||
        // Allow creating stray/shelter pets if the user's role permits (simplified check for now, trusting the email match)
        // If ownerEmail is null (stray), we allow it if user is logged in
        request.resource.data.ownerEmail == null
      );
      
      allow update, delete: if isAdmin() || (isSignedIn() && (
        resource.data.ownerEmail == request.auth.token.email || 
        request.auth.token.email in resource.data.guardianEmails
      ));
    }

    // 3. CLINICS
    match /vet_clinics/{clinicId} {
      allow read: if true;
      // Hardened Create: Vet email must match
      allow create: if isCreatingForSelf('vetEmail');
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.vetEmail == request.auth.token.email);
    }

    // 4. DONATIONS
    match /donations/{donationId} {
      // Individual read: public+paid documents OR admin
      allow read: if (resource.data.isPublic == true && resource.data.status == 'paid') || isAdmin();

      // List/query access: only admins can browse the full list;
      // aggregate queries (getCountFromServer / getAggregateFromServer) also need list permission.
      // We allow listing paid+approved donations so the public total can be summed.
      allow list: if isAdmin() ||
        (resource.data.status == 'paid' && resource.data.approved == true);

      // Hardened Create: anyone can create, but must start as pending + not yet approved
      allow create: if
        request.resource.data.status == 'pending_payment' &&
        request.resource.data.approved == false &&
        request.resource.data.numericValue > 0 &&
        request.resource.data.timestamp is number;

      allow update, delete: if isAdmin();
    }

    // 5. APPOINTMENTS
    match /appointments/{apptId} {
      allow read, write: if isSignedIn() && (
        request.auth.token.email == resource.data.vetEmail || 
        request.auth.token.email == request.resource.data.vetEmail || // for create
        exists(/databases/$(database)/documents/pets/$(resource.data.petId)) && (
          get(/databases/$(database)/documents/pets/$(resource.data.petId)).data.ownerEmail == request.auth.token.email
        )
      );
    }

    // 6. CHATS
    match /chats/{chatId} {
      allow read: if isSignedIn() && (
        request.auth.token.email == resource.data.ownerEmail || 
        request.auth.token.email == resource.data.finderEmail
      );
      
      // Hardened Write: Creation must involve the user as one of the participants
      allow create: if isSignedIn() && (
        request.resource.data.ownerEmail == request.auth.token.email || 
        request.resource.data.finderEmail == request.auth.token.email
      );
      
      allow update: if isSignedIn() && (
        resource.data.ownerEmail == request.auth.token.email || 
        resource.data.finderEmail == request.auth.token.email
      );
    }

    // 7. BLOG POSTS
    match /blog_posts/{postId} {
      allow read: if true;
      allow list: if true;
      allow write: if isAdmin();
      // Allow view increment by anyone
      allow update: if true && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']);
    }

    // 8. CONTACT MESSAGES
    match /contact_messages/{msgId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    
    // 9. ADMIN AUDIT LOGS
    match /admin_audit_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // 10. SYSTEM/MAIL
    match /mail/{mailId} {
      allow write: if isSignedIn();
    }
    
    // 11. METADATA
    match /metadata/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 12. SEARCH CONFIGURATION
    match /search_config/{configId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // 13. OPTIMIZATION TRIALS
    match /optimization_trials/{trialId} {
      allow read, list: if isAdmin();
      allow write: if isAdmin();
    }

    // 14. SEARCH INTERACTIONS
    match /search_interactions/{interactionId} {
      allow create: if true;
      allow read, list: if isAdmin();
    }

    // 15. SAVED SEARCHES
    match /saved_searches/{searchId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 16. VET VERIFICATION REQUESTS
    match /vet_verification_requests/{requestId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.vetUid == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.vetUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // 17. SYSTEM CONFIGURATION (Notifications, etc.)
    match /config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 18. SYSTEM CONFIGURATION (AI, API Keys)
    match /system_config/{configId} {
      allow read, write: if isAdmin();
    }

    // 19. FAVORITES
    match /favorites/{favoriteId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 20. ADMIN KEYS (setup codes)
    // SECURITY: Read is admin-only. Client-side key verification no longer
    // queries this collection directly — verification is done server-side via
    // the verifyAdminKey Cloud Function (Admin SDK bypasses these rules).
    match /admin_keys/{keyId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // 21. PROMO CODES
    // SECURITY NOTE: read access for signed-in users is intentional to support
    // the client-side redeemCode() query (which filters by code + status).
    // Risk: a determined signed-in user could enumerate active codes by brute-
    // forcing the query. Mitigation: code format (PAW-XXXX-XXXX) has ~10^12
    // combinations, making blind brute-force infeasible.
    // Long-term recommendation: migrate redeemCode() to a Cloud Function so
    // the promo_codes collection can be made admin-only here.
    match /promo_codes/{codeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 22. PROMO USAGE LOGS
    match /promo_usage_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    // 23. SCRAPER JOBS
    match /scraper_jobs/{jobId} {
      allow read, write: if isAdmin();
    }

    // 24. SCRAPED SIGHTINGS
    match /scraped_sightings/{sightingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- STRIPE EXTENSION RULES ---
    match /customers/{uid} {
      allow read: if request.auth.uid == uid;

      match /checkout_sessions/{id} {
        allow read, write: if request.auth.uid == uid;
      }
      match /subscriptions/{id} {
        allow read: if request.auth.uid == uid;
      }
      match /payments/{id} {
        allow read: if request.auth.uid == uid;
      }
    }

    // --- SOCIAL MEDIA MANAGEMENT RULES ---

    // Social scheduled posts - Admin only
    match /social_scheduled_posts/{postId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isSignedIn();
      allow update: if isAdmin() && isSignedIn();
      allow delete: if isAdmin() && isSignedIn();
    }

    // Social platform credentials - Admin only, encrypted
    match /social_platform_credentials/{credId} {
      allow read: if isAdmin() && isSignedIn();
      allow create: if isAdmin() && isSignedIn();
      allow update: if isAdmin() && isSignedIn();
      allow delete: if isAdmin() && isSignedIn();
    }

    // Social analytics - Read-only for admins, write-only for Cloud Functions
    match /social_analytics/{analyticsId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions can write via Admin SDK
    }

    // ====== KARMA & RIDER SYSTEM RULES ======

    // 25. KARMA TRANSACTIONS
    // Security: list is restricted to the owner's own records (prevents cross-user data leaks)
    match /karma_transactions/{txId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // 26. KARMA BALANCES
    match /karma_balances/{userId} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // 27. PATROL SESSIONS
    match /patrol_sessions/{sessionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow list: if isAdmin();
    }

    // 28. MISSIONS
    // SECURITY: update is restricted to only the fields a user may legitimately
    // modify (progress tracking). Admin creates and fully updates missions.
    // Users may only increment their own progress counter on a mission document.
    match /missions/{missionId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      // Users can only touch their own progress field; admins have full update.
      allow update: if isAdmin() || (
        isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantProgress'])
      );
    }

    // 29. PARTNER STORES
    match /partner_stores/{storeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 30. KARMA REDEMPTIONS
    match /karma_redemptions/{redemptionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    // 31. RIDER PROFILES
    match /rider_profiles/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // 32. LEADERBOARD (cached)
    match /leaderboard/{period} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}