rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // --- FUNZIONI DI SUPPORTO (Helpers) ---
    
    // Controlla se l'utente è loggato
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Controlla se l'utente sta toccando i propri file
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Controlla se l'utente è un admin
    // Nota: Le regole di storage non hanno accesso diretto a Firestore get() senza estensioni specifiche o se non si usa custom claims.
    // Se non usiamo custom claims, non possiamo facilmente fare isAdmin() qui senza duplicare la logica o usare metadati.
    // Per ora, assumiamo isSignedIn() per le cartelle condivise ma limitiamo le eliminazioni se possibile.

    // --- REGOLE SPECIFICHE PER FILE ---

    // 1. LETTURA GLOBALE
    // Necessario affinché tutti possano vedere le foto degli animali smarriti/adozioni
    match /{allPaths=**} {
      allow read: if true;
    }

    // 2. FILE UTENTI & RIFUGI (User & Shelter Files)
    match /users/{userId}/{allPaths=**} {
      allow write: if isOwner(userId);
    }

    // 2b. FOTO PROFILO (Profile Photos)
    // Legacy path — keep for backwards compat, new uploads go to users/{uid}/profile/
    match /profile_photos/{userId}/{allPaths=**} {
      allow write: if isOwner(userId);
    }
    
    match /shelters/{userId}/{allPaths=**} {
      allow write: if isOwner(userId);
    }

    // 2.5. VERIFICATIONS
    // Permette agli utenti di caricare i propri documenti di verifica
    match /verifications/{userId}/{allPaths=**} {
      allow write: if isOwner(userId);
    }

    // 3. CARTELLE ANIMALI (Pet Photos)
    // Scoped by uploader UID: path must be pets/{userId}/{petId}/filename
    // This prevents any signed-in user from overwriting another user's pet photos.
    match /pets/{userId}/{allPaths=**} {
      allow write: if isOwner(userId);
    }

    // 3b. Legacy flat path (pets/{petId}/...) — allow reads, restrict writes to signed-in
    // NOTE: New uploads should use pets/{userId}/{petId}/ path via petService.ts
    // This legacy rule is retained for backwards compatibility with existing photo URLs.
    // TODO: migrate all uploads to UID-scoped path and remove this rule.
    match /pets/{petId}/{filename} {
      allow write: if isSignedIn();
    }

    // 4. UPLOADS GENERICI (Fallback)
    // Per compatibilità con vecchie versioni del codice
    match /uploads/{allPaths=**} {
      allow write: if isSignedIn();
    }
  }
}