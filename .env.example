# PawPrintFind — Environment Variables Template
# Copy this file to .env.local and fill in your real values
# NEVER commit .env or .env.local with real API keys!
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ KEY TYPES                                                               │
# │  SERVER-ONLY  → stored in GCP Secret Manager via scripts/setup-secrets  │
# │                 NEVER bundled into the frontend (no VITE_ prefix)       │
# │  CLIENT-SIDE  → safe to ship in the browser bundle (VITE_ prefix)      │
# │                 protected by Firestore security rules + domain locks,   │
# │                 NOT by secrecy. See Firebase docs for guidance.         │
# └─────────────────────────────────────────────────────────────────────────┘

# ── SERVER-ONLY: Google Gemini AI ────────────────────────────────────────────
# Deploy to Firebase Secret Manager with: ./scripts/setup-secrets.sh
GEMINI_API_KEY=your_gemini_api_key_here

# ── SERVER-ONLY: OpenRouter AI (fallback provider) ────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── SERVER-ONLY: Stripe Payments (secret key) ────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ── SERVER-ONLY: Admin genesis key hash ──────────────────────────────────────
# SHA-256 hash of your admin genesis key (not the key itself)
GENESIS_KEY_HASH=your_sha256_hash_here

# ── CLIENT-SIDE: Stripe publishable key (safe to expose) ─────────────────────
# pk_test_... for development, pk_live_... for production
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# ── CLIENT-SIDE: App Public URL ───────────────────────────────────────────────
# Used for QR codes and deep links — no trailing slash
VITE_PUBLIC_BASE_URL=https://your-project.web.app

# ── CLIENT-SIDE: Firebase Configuration ──────────────────────────────────────
# Found in Firebase Console → Project Settings → Your apps → SDK setup
# These are intentionally public — protect them via Firestore security rules
# and by restricting your API key to your domains in GCP Console:
#   GCP → APIs & Services → Credentials → API key → Application restrictions
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-your_measurement_id
